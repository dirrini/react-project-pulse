generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id          Int      @id @default(autoincrement())
  externalCode String? @unique
  name        String
  description String
  progress    Int
  status      String
  createdAt   DateTime @default(now())
  tasks       Task[]
  users       ProjectUser[]
  products    Product[]
  integrationClients IntegrationClientProject[]
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  status      String
  projectId   Int
  project     Project  @relation(fields: [projectId], references: [id])
  createdAt   DateTime @default(now())
  users       TaskUser[]
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  role         String
  createdAt    DateTime @default(now())
  projects     ProjectUser[]
  tasks        TaskUser[]
}

model ProjectUser {
  id        Int      @id @default(autoincrement())
  projectId Int
  userId    Int
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([projectId, userId])
}

model TaskUser {
  id                 Int      @id @default(autoincrement())
  taskId             Int
  userId             Int
  status             String
  estimatedStartDate DateTime
  estimatedEndDate   DateTime
  task               Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt          DateTime @default(now())

  @@unique([taskId, userId])
}

model Product {
  id                  Int      @id @default(autoincrement())
  externalCode        String?
  status              String
  vendor              String
  materialCode        String
  quantity            Float
  materialDescription String
  deliveryDate        DateTime
  projectId           Int
  project             Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt           DateTime @default(now())

  @@unique([projectId, externalCode])
}

model IntegrationClient {
  id        Int      @id @default(autoincrement())
  name      String
  keyHash   String   @unique
  scopes    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  lastUsedAt DateTime?
  projects  IntegrationClientProject[]
}

model IntegrationClientProject {
  id                  Int      @id @default(autoincrement())
  integrationClientId Int
  projectId           Int
  integrationClient   IntegrationClient @relation(fields: [integrationClientId], references: [id], onDelete: Cascade)
  project             Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt           DateTime @default(now())

  @@unique([integrationClientId, projectId])
}
