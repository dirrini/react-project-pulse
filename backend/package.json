{
  "name": "projectpulse-api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format esm --platform node --target node22 --out-dir dist --clean",
    "start": "node dist/server.js",
    "studio": "dotenv -e .env.local -- prisma studio",
    "migrate": "dotenv -e .env.local -- prisma migrate dev"
  },
  "dependencies": {
    "@apollo/server": "^4.11.0",
    "@prisma/client": "^6.16.2",
    "body-parser": "^1.20.3",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "graphql": "^16.9.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/node": "^22.15.3",
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.16.2",
    "tsup": "^8.5.1",
    "tsx": "^4.19.1",
    "typescript": "^5.8.3"
  }
}
